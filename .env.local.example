# Firebase 설정 (Firebase 콘솔에서 복사)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# 카카오맵 API 키
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_api_key

# 카카오 로그인 (Kakao Developers — JS 키는 공개, REST 키는 비밀)
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Firebase Admin (카카오 커스텀 토큰 발급용 — 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

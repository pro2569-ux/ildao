# ===== Firebase 클라이언트 설정 (Firebase 콘솔 > 프로젝트 설정 > 내 앱) =====
# NEXT_PUBLIC_* 은 브라우저에 노출되는 공개 값이며, 빌드 시점에 번들에 인라인됨.
# (값 변경 시 반드시 재배포 필요)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ===== Firebase Admin SDK (서버 전용 — 카카오 로그인 Custom Token 발급용) =====
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성
# FIREBASE_PRIVATE_KEY 는 JSON의 private_key 값을 그대로(줄바꿈을 \n 문자로 유지한 한 줄) 입력.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===== 카카오 (Kakao Developers) =====
# JavaScript 키 — 카카오 로그인 SDK / 카카오맵 SDK 공용 (같은 값 사용 가능)
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_javascript_key
# REST API 키 — 서버 토큰 교환에 필수 (없으면 카카오 로그인 실패)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
# 선택: 미설정 시 요청 origin + /auth/kakao/callback 으로 자동 폴백
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=https://your-domain.com/auth/kakao/callback

# ===== 선택: FCM 웹 푸시 (설정 시에만 알림 기능 활성화) =====
# Firebase 콘솔 > 프로젝트 설정 > 클라우드 메시징 > 웹 푸시 인증서
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key

# ===== 선택: Sentry 에러 모니터링 (DSN 설정 시에만 활성화) =====
# sentry.io > 프로젝트 생성(Next.js) > DSN 복사
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oyyyyy.ingest.sentry.io/zzzzz
# 소스맵 업로드(선택 — 스택트레이스 가독성): SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN
# SENTRY_ORG=your_org
# SENTRY_PROJECT=ildao
# SENTRY_AUTH_TOKEN=your_auth_token
